# ========== App ==========
# Set to "production" for prod mode (switches Gin to release mode)
APP_ENV=development

# ========== Ports ==========
PORT=8080
WEB_PORT=4242

# ========== Database ==========
DB_USER=user
DB_PASSWORD=pass
DB_NAME=name
DB_SSLMODE=disable

# ========== CORS ==========
CORS_ORIGINS=http://localhost:4242

# ========== Upload ==========
MAX_UPLOAD_MB=50

# ========== ML / Ollama ==========
OLLAMA_MODEL=qwen2.5:1.5b

VITE_API_URL=http://localhost:8080
